# Video Platform - Configuration Template
# Copy this to .env and fill in your values

# ENVIRONMENT
NODE_ENV=production
PORT=3000
HOST=localhost

# DATABASE  
DATABASE_PATH=./data/video-platform.db
DATABASE_RESET=false

# EMAIL CONFIGURATION (Gmail SMTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_SERVICE=gmail
EMAIL_ENABLED=true

# JWT & SECURITY
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-strong-random-32-character-string
JWT_EXPIRY=7d
ADMIN_JWT_SECRET=change-me-to-another-strong-32-character-string
ADMIN_JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

# CORS CONFIGURATION
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_CREDENTIALS=true

# RECAPTCHA (Optional)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# SESSION CONFIGURATION
SESSION_TIMEOUT=86400000
OTP_EXPIRY=600000
MAX_LOGIN_SESSIONS=50

# LOGGING
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ADMIN ACCOUNT (auto-created on startup)
DEFAULT_ADMIN_EMAIL=admin@videochat.com
DEFAULT_ADMIN_PASSWORD=Admin@123
DEFAULT_ADMIN_ENABLED=true

# FEATURE FLAGS
FEATURE_EMAIL_VERIFICATION=true
FEATURE_LOGIN_TRACKING=true
FEATURE_GEOLOCATION=true
